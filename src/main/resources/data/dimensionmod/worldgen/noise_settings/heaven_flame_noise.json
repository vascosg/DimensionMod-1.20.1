{
  "default_block": {
    "Name": "minecraft:blackstone"
  },
  "default_fluid": {
    "Name": "minecraft:lava"
  },
  "sea_level": 0,
  "disable_mob_generation": true,
  "aquifers_enabled": false,
  "ore_veins_enabled": false,
  "legacy_random_source": false,
  "noise": {
    "min_y": -64,
    "height": 256,
    "size_horizontal": 1,
    "size_vertical": 2
  },
  "noise_router": {
    "barrier": 0,
    "fluid_level_floodedness": 0,
    "fluid_level_spread": 0,
    "lava": 0,
    "vein_toggle": 0,
    "vein_ridged": 0,
    "vein_gap": 0,
    "temperature": "dimensionmod:stable_temp",
    "vegetation": "dimensionmod:humidity_from_temp",
    "continents": "minecraft:overworld/continents",
    "erosion": "minecraft:overworld/erosion",
    "depth": "minecraft:overworld/depth",
    "ridges": "minecraft:overworld/ridges",
    "initial_density_without_jaggedness": "minecraft:overworld/jaggedness",
    "final_density": "dimensionmod:hf_noise_function"
  },
  "spawn_target": [
    {
      "temperature": 0,
      "humidity": 0,
      "continentalness": 0,
      "erosion": 0,
      "weirdness": 0,
      "depth": 0,
      "offset": 0
    }
  ],
  "surface_rule": {
    "type": "minecraft:sequence",
    "sequence": [
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:stone_depth",
          "offset": 1,
          "surface_type": "floor",
          "add_surface_depth": true,
          "secondary_depth_range": 0
        },
        "then_run": {
          "type": "minecraft:sequence",
          "sequence": [
            {
              "type": "minecraft:condition",
              "if_true": {
                "type": "minecraft:biome",
                "biome_is": [
                  "dimensionmod:hf_badlands_biome"
                ]
              },
              "then_run": {
                "type": "minecraft:block",
                "result_state": {
                  "Name": "minecraft:terracotta"
                }
              }
            },
            {
              "type": "minecraft:condition",
              "if_true": {
                "type": "minecraft:biome",
                "biome_is": [
                  "dimensionmod:hf_desert_biome"
                ]
              },
              "then_run": {
                "type": "minecraft:block",
                "result_state": {
                  "Name": "minecraft:sand"
                }
              }
            },
            {
              "type": "minecraft:condition",
              "if_true": {
                "type": "minecraft:biome",
                "biome_is": [
                  "dimensionmod:hf_nether_wastes_biome"
                ]
              },
              "then_run": {
                "type": "minecraft:sequence",
                "sequence": [
                  {
                    "type": "minecraft:condition",
                    "if_true": {
                      "type": "minecraft:noise_threshold",
                      "noise": "minecraft:surface",
                      "min_threshold": -0.4,
                      "max_threshold": 0
                    },
                    "then_run": {
                      "type": "minecraft:block",
                      "result_state": {
                        "Name": "minecraft:warped_nylium"
                      }
                    }
                  },
                  {
                    "type": "minecraft:condition",
                    "if_true": {
                      "type": "minecraft:noise_threshold",
                      "noise": "minecraft:surface",
                      "min_threshold": 0,
                      "max_threshold": 0.4
                    },
                    "then_run": {
                      "type": "minecraft:block",
                      "result_state": {
                        "Name": "minecraft:crimson_nylium"
                      }
                    }
                  },
                  {
                    "type": "minecraft:block",
                    "result_state": {
                      "Name": "minecraft:netherrack"
                    }
                  }
                ]
              }
            },
            {
              "type": "minecraft:condition",
              "if_true": {
                "type": "minecraft:biome",
                "biome_is": [
                  "dimensionmod:hf_ocean_biome",
                  "dimensionmod:hf_ocean_floor_biome"
                ]
              },
              "then_run": {
                "type": "minecraft:block",
                "result_state": {
                  "Name": "minecraft:blackstone"
                }
              }
            }
          ]
        }
      }
    ]
  }
}